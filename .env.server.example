# ===========================================================================
# OrderFlow server deployment (.env for docker compose). Copy to .env and edit.
#   cp .env.server.example .env
# ===========================================================================

# --- Domain & HTTPS (Caddy / Let's Encrypt) ---
# Your domain or subdomain, with a DNS A record pointing at this server's IP.
DOMAIN=order.example.at
# Email used by Let's Encrypt for certificate notices.
ACME_EMAIL=you@example.at

# --- Public URL of the app (used to build waiter links) ---
PUBLIC_URL=https://order.example.at

# --- Bootstrap admin (created ONCE on first start; change it in the UI after) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-ME-strong-password
# Optional bootstrap station login for Bar/Kitchen helpers (else create it in the UI):
# STATION_USERNAME=schank
# STATION_PASSWORD=another-strong-password

# --- Security ---
# Fixed secret so sessions survive restarts. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=PUT-A-LONG-RANDOM-HEX-STRING-HERE

# How long a waiter login link / session stays valid (hours).
WAITER_TOKEN_TTL_HOURS=24

# --- Localization ---
DEFAULT_LANG=de
CURRENCY=EUR
