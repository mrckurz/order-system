# Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# {$DOMAIN} and {$ACME_EMAIL} are read from the environment (see docker-compose.yml / .env).
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip
	reverse_proxy app:3000
}

# Redirect www.<domain> to the canonical root domain (gets its own HTTPS cert).
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
