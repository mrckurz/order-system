# --- Server ---
PORT=3000
# Public base URL of the API server itself.
PUBLIC_URL=http://localhost:3000

# Where the PWA frontend is hosted. Used to build waiter login links.
# - Backend-served mode: leave empty (links use PUBLIC_URL).
# - Hybrid mode (PWA on GitHub Pages): set to the Pages app URL, e.g.
#   https://your-user.github.io/order-system
FRONTEND_URL=

# Allowed CORS origin(s) for the API + websockets. Comma-separated, or "*".
# - Backend-served mode: "*" is fine (same origin anyway).
# - Hybrid mode: set to your GitHub Pages origin, e.g. https://your-user.github.io
CORS_ORIGIN=*

# SQLite database file location. In containers, point this at a mounted volume
# so data survives restarts, e.g. /data/orderflow.db
# DB_PATH=

# --- Security ---
# Password the organizer uses to open the Admin, Bar and Kitchen screens.
# CHANGE THIS before going live.
ADMIN_PASSWORD=changeme
# Secret used to sign admin session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left empty a random secret is generated on each start (logs everyone out on restart).
SESSION_SECRET=

# Default validity of a waiter login link, in hours (admin can override per waiter).
WAITER_TOKEN_TTL_HOURS=24

# --- Localization ---
# Default UI language: de or en
DEFAULT_LANG=de
# ISO currency code used for formatting prices
CURRENCY=EUR

# --- Printer (kitchen / Speisenausgabe) ---
# none    = no printing, tickets are logged to console (and ./spool when SPOOL=1)
# network = ESC/POS thermal printer reachable over TCP (e.g. Epson TM-series)
PRINTER_TYPE=none
PRINTER_HOST=192.168.0.50
PRINTER_PORT=9100
# Characters per line of the printer (58mm ~ 32, 80mm ~ 42/48)
PRINTER_WIDTH=42
# Write a copy of every ticket to ./spool for debugging (1 = on)
SPOOL=0
